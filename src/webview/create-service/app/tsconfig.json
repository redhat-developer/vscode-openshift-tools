{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2015",
        "outDir": "creatServiceView",
        "lib": [
            "es2015",
            "dom"
        ],
        "jsx": "react-jsx",
        "sourceMap": true,
        "noUnusedLocals": true,
        // "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "experimentalDecorators": true,
        "typeRoots": [
            "../../../../node_modules/@types",
            "../../@types"
        ],
        "baseUrl": ".",
        "skipLibCheck": true,
        "ignoreDeprecations": "6.0"
    },
    "exclude": [
        "node_modules"
    ]
}
