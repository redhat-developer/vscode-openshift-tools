{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "rootDir": "..",
        "outDir": "../../out",
        "target": "es2015",
        "lib": ["es2017", "dom"],
        "jsx": "react-jsx",
        "types": ["node"],
        "typeRoots": [
            "../../node_modules/@types",
            "@types"
        ],
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "incremental": true,
        "ignoreDeprecations": "6.0",
        "noImplicitAny": false,
        "strict": false,
        "strictNullChecks": false
    },
    "include": [
        "ambient.d.ts",
        "*/app/**/*.ts",
        "*/app/**/*.tsx",
        "common/*.tsx",
        "common/*.ts",
        "create-deployment/pages/builderImageListItem.tsx",
        "create-deployment/pages/builderConfig.tsx",
        "../devfile-registry/devfileInfo.ts"
    ],
}
