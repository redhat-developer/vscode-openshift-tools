{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "target": "es2015",
        "outDir": "openshiftTerminal",
        "lib": [
            "es2015",
            "dom"
        ],
        "jsx": "react-jsx",
        "sourceMap": true,
        "noUnusedLocals": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "experimentalDecorators": true,
        "baseUrl": ".",
        "typeRoots": [
            "../../../../node_modules/@types",
            "../../@types"
        ]
    },
    "exclude": [
        "node_modules"
    ]
}
