{
  "compilerOptions": {
    "outDir": "./out",
    "rootDir": ".",
    "paths": {
      "clipboardy": ["out/esm/clipboardy.cjs"],
      "got": ["out/esm/got.cjs"],
      "@kubernetes/client-node": ["out/esm/k8s-client-node.cjs"]
    },
    "baseUrl": ".",
    "jsx": "react",
    "lib": [
        "es6",
        "dom"
    ],
    "noEmit": false,
    "module": "CommonJS",
    "target": "es6",
    "esModuleInterop": true,
    "strict": false,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "noImplicitOverride": false,
    "skipLibCheck": true,
    "incremental": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "types": ["mocha", "node"],
    "typeRoots": [ "./src/@types-ignore", "./src/@types", "./node_modules/@types", "./out/extension"],
    "sourceMap": true
  },
  "include": ["test/**/*.ts", "src/**/*.ts"
],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "test-resources",
    "src/webview/**/app/**/*",
    "src/webview/common/**/*"
  ]
}